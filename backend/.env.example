# Anthropic API key for Claude narrative generation
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (current Opus). Use claude-sonnet-4-6 for cheaper/faster narrative.
CLAUDE_MODEL=claude-opus-4-8

# Data source: "seed" (local SQLite, hybrid demo) | "coupler" (live Coupler.io MCP)
WARROOM_SOURCE=seed

# Required when WARROOM_SOURCE=coupler — Personal Access Token from app.coupler.io/app/mcp/
COUPLER_ACCESS_TOKEN=

# --- Coupler real-source mapping (only used when WARROOM_SOURCE=coupler) ---
# Discover these by running:  python -m warroom.coupler_check  [<table>]
# The data flow id/name to query (from list-dataflows). Leave blank if not needed.
COUPLER_DATAFLOW=
# The table/dataset name inside the flow snapshot to read (SELECT * FROM <this>).
COUPLER_TABLE=ads_daily
# The get-data tool's SQL argument name (coupler_check prints the tool's args).
COUPLER_QUERY_ARG=query
# Map your real columns -> canonical fields (JSON). Omit fields that already match.
# Example: {"date":"day","channel":"platform","campaign":"campaign_name",
#           "country":"country_code","spend":"cost","conversions":"conv","revenue":"conv_value"}
COUPLER_COLMAP=
# Channel label to use if the flow is single-platform (no channel column).
COUPLER_CHANNEL_DEFAULT=Meta

# Path to the local seed SQLite snapshot (same schema the Coupler MCP get-data returns)
WARROOM_DB=data/sample_metrics.db

# Simulated Coupler refresh cadence in seconds (real Coupler refreshes every ~15 min = 900s).
# Kept short in seed mode so the dashboard visibly pulses during a demo.
REFRESH_SECONDS=20
