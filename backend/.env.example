# Anthropic API key for Claude narrative generation
ANTHROPIC_API_KEY=sk-ant-...

# Claude model (current Opus). Use claude-sonnet-4-6 for cheaper/faster narrative.
CLAUDE_MODEL=claude-opus-4-8

# Data source: "seed" (local SQLite, hybrid demo) | "coupler" (live Coupler.io MCP)
WARROOM_SOURCE=seed

# Required when WARROOM_SOURCE=coupler — Personal Access Token from app.coupler.io/app/mcp/
COUPLER_ACCESS_TOKEN=

# Path to the local seed SQLite snapshot (same schema the Coupler MCP get-data returns)
WARROOM_DB=data/sample_metrics.db

# Simulated Coupler refresh cadence in seconds (real Coupler refreshes every ~15 min = 900s).
# Kept short in seed mode so the dashboard visibly pulses during a demo.
REFRESH_SECONDS=20
